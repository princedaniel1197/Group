# ---------------------------------------------------------------------------
# keepsake environment (spec §4)
# Copy to .env.local and fill in. NEVER commit .env.local. NEVER expose any of
# these to the client — none are prefixed NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

# Railway Postgres — inject via a Railway variable reference.
DATABASE_URL=

# Railway Bucket (S3-compatible). Map Railway's injected bucket credentials here.
S3_ENDPOINT=          # bucket endpoint URL, e.g. https://xxxx.up.railway.app
S3_REGION=            # bucket region, e.g. us-east-1 (any value the bucket accepts)
S3_BUCKET=            # bucket name (display name + hash)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# The shared secret friends type once to become contributors.
CONTRIBUTOR_PASSPHRASE=

# Signs the contributor cookie. Generate 32+ random bytes, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Unused in v1; present so enrichment (§8) can be turned on later.
ANTHROPIC_API_KEY=
